{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maat",
  "version": "0.1.0",
  "identifier": "studio.sunday.maat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Maat",
        "width": 1180,
        "height": 820,
        "minWidth": 720,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [],
    "category": "DeveloperTool",
    "shortDescription": "Git-backed project memory for agents",
    "longDescription": "Maat is a Git-backed project memory for agent-run work.",
    "macOS": {
      "hardenedRuntime": true,
      "minimumSystemVersion": "12.0"
    }
  }
}
